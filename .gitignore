# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/dist/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets managed via Infisical, no local .env files needed
.env*
# .infisical.json is intentionally committed (project config only, no secrets)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# AI agent configs
.agents/
.claude/
.gemini/
PROCEDURES.md
GEMINI.md

# generated / build artifacts
graphify-out/
saved-searches.json
skills-lock.json

# scratch / misc
mem0_quickstart.py

# project docs / tracking (tracked per-user, not in repo)
PROGRESS.md
README.md
.env*.local

# generated / runtime data (not code)
data/

# safety: never reference the old IIE account from this repo
btwndlinez
